            background: linear-gradient(135deg, #EF444420 0%, #EF444405 100%);
            border-bottom: 2px solid #EF444440;
        }
        
        /* Block cards with chapter color - v8 style */
        .block-card {
            background: #EF444415;
            border: 1px solid #EF444440;
            transition: all 0.3s ease;
        }
        
        .block-card:hover {
            background: #EF444425;
            border-color: #EF444470;
            transform: translateY(-4px);
            box-shadow: 0 10px 30px -10px #EF444440;
        }
        
        .block-completed {
